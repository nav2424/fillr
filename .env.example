# Fillr Environment Variables
# Copy to .env and fill in your values

# App Store product URL for “Share Fillr” on iOS (e.g. https://apps.apple.com/app/fillr/id1234567890)
# EXPO_PUBLIC_IOS_APP_STORE_URL=

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxx
EXPO_PUBLIC_FACEBOOK_APP_ID=123456789012345
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=your-facebook-client-token
EXPO_PUBLIC_FACEBOOK_DISPLAY_NAME=Fillr

# Legal URLs (Terms & Privacy — shown in onboarding disclaimer and Profile)
# EXPO_PUBLIC_TERMS_URL=https://www.usefillr.com/terms.html
# EXPO_PUBLIC_PRIVACY_URL=https://www.usefillr.com/privacy.html

# OpenAI
# IMPORTANT: do NOT expose your OpenAI key in EXPO_PUBLIC_ vars.
# Set OPENAI_API_KEY as a Supabase Edge Function secret instead:
#   supabase secrets set OPENAI_API_KEY=sk-...
# The app calls /functions/v1/ingredient-analysis with anon auth.
# Optional overrides (default: gpt-4o-mini for speed; use gpt-4o for quality)
# EXPO_PUBLIC_OPENAI_INGREDIENT_MODEL=gpt-4o
# EXPO_PUBLIC_OPENAI_MODEL=
